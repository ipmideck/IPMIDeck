#!/bin/sh
# IPMIDeck local test gate — the FIRST gate. CI runs the same checks in the cloud
# (.github/workflows/gate.yml, called by ci.yml on push/PR) plus an `npx tsc -b --noEmit`
# typecheck. POSIX sh so it runs under the bundled Git-Bash on Windows. Activate per-clone with:
#   git config core.hooksPath .githooks
set -e
echo "[pre-commit] ruff lint"
python -m ruff check backend tests
echo "[pre-commit] backend tests + coverage gate"
python -m pytest --cov --cov-report=term-missing
echo "[pre-commit] i18n parity"
node scripts/check-i18n-parity.mjs
echo "[pre-commit] frontend tests"
( cd frontend && npm run test )
echo "[pre-commit] SPA freshness (backend/static == a clean build of frontend/src)"
node scripts/check-spa-built.mjs
